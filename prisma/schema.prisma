generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  patient
  admin
  doctor
  receptionist
}

enum ServiceType {
  service
  procedure
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  cancelled
  no_show
}

enum AppointmentPaymentStatus {
  pending
  paid
  refunded
}

enum PaymentMethod {
  cash
  card
  bkash
  nagad
  bank
  other
}

enum InvoiceStatus {
  draft
  sent
  paid
  partial
  overdue
  cancelled
}

enum DiscountType {
  fixed
  percent
}

enum CommissionType {
  fixed
  percent
}

enum TreatmentSessionStatus {
  in_progress
  completed
  cancelled
}

enum TreatmentPlanStatus {
  active
  completed
  cancelled
}

enum TreatmentPlanItemStatus {
  pending
  in_progress
  completed
  skipped
}

enum PhotoType {
  before
  after
  xray
  intraoral
  other
}

enum PatientGender {
  male
  female
  other
}

// ─── Auth & User Management ────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(patient)
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions            Session[]
  accounts            Account[]
  doctor              Doctor?
  patient             Patient?
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ─── RBAC ──────────────────────────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([roleId])
  @@index([permissionId])
}

// ─── Services ──────────────────────────────────────────────────────────────────

model Service {
  id            Int         @id @default(autoincrement())
  name          String
  nameEn        String?
  slug          String      @unique
  description   String?
  descriptionEn String?
  price         Decimal?    @db.Decimal(10, 2)
  priceMax      Decimal?    @db.Decimal(10, 2)
  priceNote     String?
  type          ServiceType @default(service)
  category      String?
  duration      Int?
  image         String?
  icon          String?
  color         String?
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  subServices        SubService[]
  doctorServices     DoctorService[]
  appointments       Appointment[]
  invoiceItems       InvoiceItem[]
  treatmentPlanItems TreatmentPlanItem[]
}

model SubService {
  id        Int      @id @default(autoincrement())
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal? @db.Decimal(10, 2)
  showPrice Boolean  @default(true)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
}

// ─── Doctors ───────────────────────────────────────────────────────────────────

model Doctor {
  id                  Int      @id @default(autoincrement())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileImage        String?
  specialization      String?
  specializationEn    String?
  nameEn              String?
  qualification       String?
  experience          Int?
  bio                 String?
  licenseNumber       String?
  isAvailable         Boolean  @default(true)
  consultationFee     Decimal? @db.Decimal(10, 2)
  workingHours        Json?
  phone2              String?
  educationBackground String?
  educationDocument   String?
  fatherName          String?
  fatherPhone         String?
  motherName          String?
  motherPhone         String?
  nidCopy             String?
  agreementPaper      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  services          DoctorService[]
  appointments      Appointment[]
  treatmentSessions TreatmentSession[]
  treatmentPlans    TreatmentPlan[]
  invoices          Invoice[]
}

model DoctorService {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([serviceId])
}

// ─── Scheduling ────────────────────────────────────────────────────────────────

model ClinicSchedule {
  id              Int      @id @default(autoincrement())
  dayOfWeek       Int
  isOpen          Boolean  @default(true)
  openTime        String
  closeTime       String
  slotDuration    Int      @default(30)
  breakStart      String?
  breakEnd        String?
  maxAppointments Int?     @default(20)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ScheduleOverride {
  id        Int      @id @default(autoincrement())
  date      DateTime
  isOpen    Boolean  @default(false)
  openTime  String?
  closeTime String?
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// ─── Referrers ─────────────────────────────────────────────────────────────────

model Referrer {
  id              Int            @id @default(autoincrement())
  name            String
  phone           String?
  type            String         @default("other")
  commissionType  CommissionType @default(fixed)
  commissionValue Decimal        @default(0) @db.Decimal(10, 2)
  isActive        Boolean        @default(true)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  patients Patient[]
}

// ─── Patients ──────────────────────────────────────────────────────────────────

model Patient {
  id                       Int            @id @default(autoincrement())
  userId                   String         @unique
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileImage             String?
  dateOfBirth              DateTime?
  age                      Int?
  gender                   PatientGender?
  address                  String?
  bloodGroup               String?
  phone2                   String?
  whatsappNumber           String?
  facebookId               String?
  referralSource           String?
  referralDetails          String?
  referrerId               Int?
  referrer                 Referrer?      @relation(fields: [referrerId], references: [id], onDelete: SetNull)
  isChildPatient           Boolean        @default(false)
  guardianName             String?
  guardianRelation         String?
  guardianPhone            String?
  dentalPreviousTreatment  Boolean        @default(false)
  dentalPreviousNotes      String?
  dentalDocuments          Json?
  dentalCurrentProblem     String?
  generalPreviousTreatment Boolean        @default(false)
  generalPreviousNotes     String?
  generalDocuments         Json?
  generalCurrentProblem    String?
  allergies                String?
  currentMedicines         String?
  medicalNotes             String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  appointments      Appointment[]
  visits            PatientVisit[]
  medicalResponses  PatientMedicalResponse[]
  treatmentSessions TreatmentSession[]
  invoices          Invoice[]
  payments          Payment[]
  treatmentPlans    TreatmentPlan[]
  consentForms      ConsentForm[]
  photos            PatientPhoto[]
}

// ─── Appointments ──────────────────────────────────────────────────────────────

model Appointment {
  id              Int                      @id @default(autoincrement())
  patientId       Int?
  patient         Patient?                 @relation(fields: [patientId], references: [id], onDelete: SetNull)
  guestName       String?
  guestPhone      String?
  guestEmail      String?
  doctorId        Int?
  doctor          Doctor?                  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  serviceId       Int?
  service         Service?                 @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  appointmentDate DateTime
  timeSlot        String                   @default("--:--")
  duration        Int                      @default(30)
  status          AppointmentStatus        @default(pending)
  notes           String?
  symptoms        String?
  diagnosis       String?
  prescription    String?
  documents       Json?
  price           Decimal?                 @db.Decimal(10, 2)
  paymentStatus   AppointmentPaymentStatus @default(pending)
  createdBy       String?
  createdByUser   User?                    @relation("AppointmentCreatedBy", fields: [createdBy], references: [id])
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentDate])
  @@index([status])
  @@index([guestPhone])
}

model PatientVisit {
  id                 Int      @id @default(autoincrement())
  patientId          Int
  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visitDate          String
  visitReason        String?
  problemDescription String?
  documents          Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([patientId])
}

// ─── Dynamic Medical Form Builder ──────────────────────────────────────────────

model MedicalQuestion {
  id                  Int              @id @default(autoincrement())
  title               String
  description         String?
  fieldType           String
  placeholder         String?
  isRequired          Boolean          @default(false)
  isActive            Boolean          @default(true)
  sortOrder           Int              @default(0)
  conditionQuestionId Int?
  conditionQuestion   MedicalQuestion? @relation("QuestionCondition", fields: [conditionQuestionId], references: [id])
  conditionValue      String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  options            MedicalQuestionOption[]
  responses          PatientMedicalResponse[]
  dependentQuestions MedicalQuestion[]       @relation("QuestionCondition")
}

model MedicalQuestionOption {
  id         Int             @id @default(autoincrement())
  questionId Int
  question   MedicalQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String
  value      String
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([questionId])
}

model PatientMedicalResponse {
  id             Int             @id @default(autoincrement())
  patientId      Int
  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  questionId     Int
  question       MedicalQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responseText   String?
  responseValues Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([patientId])
  @@index([questionId])
}

// ─── Treatment Sessions & Clinical Records ─────────────────────────────────────

model TreatmentSession {
  id             Int                    @id @default(autoincrement())
  patientId      Int
  patient        Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       Int?
  doctor         Doctor?                @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  sessionNumber  Int                    @default(1)
  specialization String                 @default("general")
  status         TreatmentSessionStatus @default(in_progress)
  chiefComplaint String?
  diagnosis      Json?
  treatmentDone  String?
  notes          String?
  prescriptions  Json?
  vitals         Json?
  toothChart     Json?
  sessionDate    DateTime
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  invoices     Invoice[]
  consentForms ConsentForm[]
  photos       PatientPhoto[]
}

// ─── Billing & Invoicing ───────────────────────────────────────────────────────

model Invoice {
  id                 Int               @id @default(autoincrement())
  patientId          Int
  patient            Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId           Int?
  doctor             Doctor?           @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  treatmentSessionId Int?
  treatmentSession   TreatmentSession? @relation(fields: [treatmentSessionId], references: [id], onDelete: SetNull)
  invoiceNumber      String            @unique
  status             InvoiceStatus     @default(draft)
  subtotal           Decimal           @default(0) @db.Decimal(10, 2)
  discount           Decimal           @default(0) @db.Decimal(10, 2)
  discountType       DiscountType?
  tax                Decimal           @default(0) @db.Decimal(10, 2)
  total              Decimal           @default(0) @db.Decimal(10, 2)
  amountPaid         Decimal           @default(0) @db.Decimal(10, 2)
  notes              String?
  dueDate            DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  items    InvoiceItem[]
  payments Payment[]
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId   Int?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id        Int           @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  patientId Int
  patient   Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod @default(cash)
  reference String?
  notes     String?
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// ─── Treatment Plans ───────────────────────────────────────────────────────────

model TreatmentPlan {
  id        Int                 @id @default(autoincrement())
  patientId Int
  patient   Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId  Int?
  doctor    Doctor?             @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  title     String              @default("Treatment Plan")
  status    TreatmentPlanStatus @default(active)
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  items TreatmentPlanItem[]
}

model TreatmentPlanItem {
  id            Int                     @id @default(autoincrement())
  planId        Int
  plan          TreatmentPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  serviceId     Int?
  service       Service?                @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  toothNumbers  Json?
  procedure     String
  description   String?
  estimatedCost Decimal?                @default(0) @db.Decimal(10, 2)
  status        TreatmentPlanItemStatus @default(pending)
  priority      Int                     @default(1)
  completedAt   DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
}

// ─── Prescription Templates ────────────────────────────────────────────────────

model PrescriptionTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  medicines Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Consent Forms ─────────────────────────────────────────────────────────────

model ConsentForm {
  id                 Int               @id @default(autoincrement())
  patientId          Int
  patient            Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatmentSessionId Int?
  treatmentSession   TreatmentSession? @relation(fields: [treatmentSessionId], references: [id], onDelete: SetNull)
  formType           String            @default("general")
  content            String?
  signature          String?
  signedAt           DateTime?
  ipAddress          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

// ─── Patient Photos ────────────────────────────────────────────────────────────

model PatientPhoto {
  id                 Int               @id @default(autoincrement())
  patientId          Int
  patient            Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatmentSessionId Int?
  treatmentSession   TreatmentSession? @relation(fields: [treatmentSessionId], references: [id], onDelete: SetNull)
  photoType          PhotoType         @default(other)
  photoData          String
  caption            String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

// ─── Categories ────────────────────────────────────────────────────────────────

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  icon        String?
  color       String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
}
